{
  "expo": {
    "name": "Eaze Apt",
    "slug": "NeighbourHub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "eazeapt",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.eazeapt.app"
    },
    "edgeToEdgeEnabled": true,
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Eaze Apt needs access to your photos to share food images.",
          "cameraPermission": "Eaze Apt needs access to your camera to take food photos."
        }
      ],
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6c63ff",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2f5ec11-6c0c-45f9-9a82-8da683d11ded"
      }
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/f2f5ec11-6c0c-45f9-9a82-8da683d11ded"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "android": {
      "package": "com.eazeapt.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
